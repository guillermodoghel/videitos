// Prisma schema - PostgreSQL with "videitos" schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
  schemas   = ["videitos"]
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  password              String
  role                  String    @default("user") // "user" | "admin"
  name                  String?
  googleAiStudioApiKey  String?
  runwayApiKey          String?
  dropboxAccessToken    String?
  dropboxRefreshToken   String?
  dropboxTokenExpiresAt DateTime?
  dropboxAccountId      String?
  creditBalance                Decimal   @default(0) @db.Decimal(14, 4)
  stripeCustomerId             String?
  stripeDefaultPaymentMethodId String?
  autoRechargeEnabled          Boolean   @default(false)
  autoRechargeThreshold        Decimal?  @db.Decimal(14, 4) // credits threshold to trigger recharge
  autoRechargeAmount           Decimal?  @db.Decimal(14, 4) // credits to add on recharge
  autoRechargeLastTriggeredAt  DateTime?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt
  sessions                     Session[]
  templates                    Template[]
  jobs                         Job[]
  creditTransactions           CreditTransaction[]

  @@schema("videitos")
}

model Template {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                  String
  model                 String
  enabled               Boolean  @default(true)
  config                Json
  dropboxSourcePath     String?
  dropboxSourceCursor   String?
  dropboxDestinationPath String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  jobs                  Job[]

  @@schema("videitos")
}

model Job {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId            String
  template              Template  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  status                String    // queued | processing | completed | failed
  dropboxSourceFilePath String
  dropboxSourceFileId    String?   // optional: use id for download to avoid path encoding issues
  providerOperationId   String?   // Veo operation name or Runway task id
  sentAt                DateTime? // when job was sent to provider
  rateLimitClaimedAt    DateTime? // set when claiming a rate-limit slot (before calling provider)
  outputDropboxPath     String?
  preGenImageKey        String?   // S3 key of pre-generation (text-to-image) output for display
  errorMessage          String?
  apiCost               Decimal?  @db.Decimal(14, 4) // API cost (credits) when completed
  creditCost            Decimal?  @db.Decimal(14, 4) // user credit charge when completed
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  completedAt           DateTime?
  creditTransactions    CreditTransaction[]

  @@schema("videitos")
}

model CreditTransaction {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount                Decimal   @db.Decimal(14, 4) // positive = grant, negative = spend
  jobId                 String?   // set when amount is a spend for this job
  job                   Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  kind                  String    // "grant" | "spend" | "purchase" | "auto_recharge"
  description           String?
  externalId            String?   @unique // Stripe PaymentIntent ID for dedup
  stripeNetAmountCents  Int?      // net amount after Stripe fees (for purchase/auto_recharge), from webhook
  stripeFeeCents        Int?      // Stripe fee for this transaction (for purchase/auto_recharge), from webhook
  createdAt             DateTime  @default(now())

  @@schema("videitos")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@schema("videitos")
}
