# Videitos — copy to .env.local and fill in values.
# See README.md and docs/architecture.md for setup details.

# -----------------------------------------------------------------------------
# Database (PostgreSQL, schema: videitos)
# -----------------------------------------------------------------------------
# Pooled URL for Prisma Client (e.g. Vercel Postgres pooled connection)
POSTGRES_PRISMA_URL="postgresql://user:password@localhost:5432/videitos?schema=videitos"
# Direct URL for migrations (non-pooled, port 5432)
POSTGRES_URL_NON_POOLING="postgresql://user:password@localhost:5432/videitos?schema=videitos"

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Public base URL for OAuth redirects, workflow callbacks, Stripe return URLs
HOSTNAME="http://localhost:3000"
# Secret for signing session cookies and thumbnail tokens (use a long random string)
SESSION_SECRET="changeme-use-openssl-rand-hex-32"

# -----------------------------------------------------------------------------
# Dropbox (OAuth + webhook verification)
# -----------------------------------------------------------------------------
DROPBOX_APP_KEY=""
DROPBOX_APP_SECRET=""

# -----------------------------------------------------------------------------
# Stripe (credits / checkout)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# -----------------------------------------------------------------------------
# AWS S3 (source thumbnails, pre-gen images, pending video cache)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="videitos-dev"
AWS_REGION="us-east-1"

# -----------------------------------------------------------------------------
# Internal API secrets
# -----------------------------------------------------------------------------
# Guards POST /api/jobs/workflow/process, start-execution, and legacy claim-and-process
JOB_PROCESS_SECRET="changeme"
# Guards POST /api/users (admin user creation)
USER_CREATE_SECRET_TOKEN="changeme"

# -----------------------------------------------------------------------------
# Per-user secrets (NOT env vars — stored in DB, set in Dashboard → Settings)
# -----------------------------------------------------------------------------
# runwayApiKey       — Runway API key; if unset, platform uses first admin's key
# googleAiStudioApiKey — optional; used for some template features
# Dropbox tokens     — stored after OAuth connect per user
